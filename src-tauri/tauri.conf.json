{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wuthering Waves Companion",
  "version": "0.7.5",
  "identifier": "com.trung.wuwa-companion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Wuthering Waves Companion",
        "width": 960,
        "height": 640,
        "minWidth": 460,
        "minHeight": 520,
        "resizable": true,
        "center": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/trungtq2311/wuwa-companion/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJBMkVBOERENTZBRjVERkMKUldUOFhhOVczYWd1S29PL2xtOWwwTkw5bytsOXEvVU0xWUpxWnFYd2wxeDRoM0tUTkR0M3ExWlQK"
    }
  }
}
